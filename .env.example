ADMIN_EMAILS=admin@example.com
AUTH_MODE=jwt

# Required for the Docker Compose app. Generate with:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=

# Backend provider credentials live in backend/.env.
# Copy backend/.env.example to backend/.env and set GEMINI_API_KEY there.

# Local Docker Compose Postgres settings. These are development defaults only.
POSTGRES_DB=kintiga
POSTGRES_DB_LIVE=kintiga_live
POSTGRES_USER=kintiga
POSTGRES_PASSWORD=kintiga_dev_password
