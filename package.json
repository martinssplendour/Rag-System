{
  "name": "kintiga-evidence-assistant",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "npm run app",
    "app": "docker-compose up --build",
    "app:mock": "docker-compose -f docker-compose.yml -f docker-compose.mock.yml up --build",
    "start:live": "npm run app:live",
    "app:live": "docker-compose -f docker-compose.yml -f docker-compose.live.yml up --build",
    "db:dev": "docker-compose -f docker-compose.yml -f docker-compose.dev.yml up -d --force-recreate postgres",
    "app:down": "docker-compose down",
    "db:dev:down": "docker-compose -f docker-compose.yml -f docker-compose.dev.yml down",
    "app:down:mock": "docker-compose -f docker-compose.yml -f docker-compose.mock.yml down",
    "app:down:live": "docker-compose -f docker-compose.yml -f docker-compose.live.yml down",
    "app:logs": "docker-compose logs -f"
  }
}
