APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173

# For split local development, start Postgres with `npm run db:dev` from the repo root.
DATABASE_URL=postgresql+asyncpg://kintiga:kintiga_dev_password@localhost:5433/kintiga
STORAGE_BACKEND=local
LOCAL_STORAGE_DIR=./data/uploads
CHROMA_PERSIST_DIR=./data/chroma

# AUTH_MODE: disabled (default, local-dev/tests -- always uses DEFAULT_WORKSPACE_ID) | jwt | api_key
# jwt requires JWT_SECRET (the app refuses to start without it in jwt mode).
# api_key requires APP_API_KEY and callers send it as X-API-Key.
# Generate secrets with: python -c "import secrets; print(secrets.token_urlsafe(32))"
AUTH_MODE=disabled
APP_API_KEY=change-me
DEFAULT_WORKSPACE_ID=00000000-0000-0000-0000-000000000001
ADMIN_EMAILS=admin@example.com
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=60

# EMBEDDING_PROVIDER: gemini (default, real semantic retrieval) | openai | mock
# Mock embeddings are only for CI/offline smoke tests. Do not use mock embeddings
# to judge retrieval quality.
EMBEDDING_PROVIDER=gemini
EMBEDDING_MODEL=models/gemini-embedding-001
EMBEDDING_DIMENSION=3072
OPENAI_API_KEY=

# Required for the default live Gemini mode. GOOGLE_API_KEY is accepted as an alias by the chat
# provider, but set GEMINI_API_KEY for both embeddings and answer generation.
GEMINI_API_KEY=

MAX_UPLOAD_BYTES=10485760
MAX_DIRECT_TEXT_CHARS=200000
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
INGESTION_WORKER_ENABLED=true
INGESTION_WORKER_POLL_SECONDS=0.25
INGESTION_JOB_MAX_ATTEMPTS=3

# Part 2: retrieval and answer generation.
# LLM_PROVIDER: gemini (default) | openai | azure_openai | mock
LLM_PROVIDER=gemini
CHAT_MODEL=gemini-3.5-flash
LLM_TIMEOUT_SECONDS=45
LLM_MAX_RETRIES=2
GOOGLE_API_KEY=

# Optional evaluator overrides. The evaluator otherwise uses EVAL_DATABASE_URL, DATABASE_URL,
# then the Settings().database_url value above.
EVAL_DATABASE_URL=
EVAL_POSTGRES_MAINTENANCE_DB=postgres

AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=
AZURE_OPENAI_CHAT_DEPLOYMENT=
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=

CHROMA_COLLECTION_NAME=market_access_chunks
RETRIEVAL_CANDIDATE_COUNT=12
RETRIEVAL_CONTEXT_COUNT=5
RETRIEVAL_MIN_SIMILARITY=0.75
RETRIEVAL_HIGH_CONFIDENCE_SIMILARITY=0.75
RETRIEVAL_MAX_CHUNKS_PER_DOCUMENT=3
RETRIEVAL_MAX_CONTEXT_CHARS=12000
RETRIEVAL_CACHE_ENABLED=true
RETRIEVAL_CACHE_TTL_SECONDS=900
RETRIEVAL_CACHE_MAX_ENTRIES=256
RETRIEVAL_CACHE_SIMILARITY_THRESHOLD=0.97
RETRIEVAL_CHUNK_CACHE_MAX_ENTRIES=1024
PROMPT_VERSION=1.0.0
